# Frontend shell environment variables
# This project currently runs in mock-data mode.
# Only the variables below are read by the app.

# -----------------------------------------------------------------------------
# CMS provider switch
# -----------------------------------------------------------------------------
# mock | payload
PUBLIC_CMS_PROVIDER=payload

# Payload base URL (required when PUBLIC_CMS_PROVIDER=payload)
# Example: https://your-payload-app.vercel.app
PUBLIC_PAYLOAD_URL=https://payload-website-starter-ivory-one.vercel.app

# Payload API base path (optional)
# Default: /api
PUBLIC_PAYLOAD_API_BASE_PATH=/api

# Optional: customize Payload globals/collection slugs to match your backend
PUBLIC_PAYLOAD_SETTINGS_GLOBAL=site-settings
PUBLIC_PAYLOAD_NAV_COLLECTION=navigation
PUBLIC_PAYLOAD_PAGE_COLLECTION=pages
PUBLIC_PAYLOAD_SECTION_COLLECTION=ui-sections
PUBLIC_PAYLOAD_ASSET_COLLECTION=ui-assets
PUBLIC_PAYLOAD_CATEGORY_COLLECTION=categories
PUBLIC_PAYLOAD_PRODUCT_COLLECTION=products
PUBLIC_PAYLOAD_COLLECTION_PANEL_COLLECTION=collection-panels

# -----------------------------------------------------------------------------
# Image URL fallback (used by src/lib/utils/image.ts)
# -----------------------------------------------------------------------------
# Generic media base URL for relative asset paths.
# Example: https://example.com
PUBLIC_MEDIA_BASE_URL=

# Optional CDN base URL for images. If set, it takes priority for relative paths.
# Example: https://cdn.example.com
PUBLIC_R2_CDN_URL=

# -----------------------------------------------------------------------------
# Analytics snippet (used by +layout.svelte / CSP allowlist in svelte.config.js)
# -----------------------------------------------------------------------------
# Paste a full script tag when needed, for example:
# <script defer src="https://analytics.example.com/script.js" data-website-id="xxx"></script>
PUBLIC_ANALYTICS_CODE=
